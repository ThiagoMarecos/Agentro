# ===========================================
# Nexora - Variables de Entorno
# ===========================================
# Copiar a .env y completar los valores

# --- App ---
APP_NAME=Nexora
ENVIRONMENT=development
DEBUG=true
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# --- Base de datos ---
DATABASE_URL=postgresql+psycopg://nexora:nexora_secret@localhost:5432/nexora

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Seguridad ---
SECRET_KEY=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Google OAuth ---
# Obtener credenciales en Google Cloud Console:
# 1. Crear proyecto o usar existente
# 2. APIs & Services > Credentials > Create Credentials > OAuth 2.0 Client ID
# 3. Tipo: Web application
# 4. Authorized redirect URIs: http://localhost:8000/api/v1/auth/google/callback (dev)
# 5. Copiar Client ID y Client Secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Opcional: si vacío, se usa {BACKEND_URL}/api/v1/auth/google/callback
GOOGLE_REDIRECT_URI=

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# --- Frontend (para Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
